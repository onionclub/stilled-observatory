---
import '../styles/global.css';
import { pingIntelligenceSources } from '../utils/ping';

interface Props {
  title?: string;
  activePath?: string;
}

const { title = "The Observatory | Stilled.", activePath = "/" } = Astro.props;
const pings = await pingIntelligenceSources();

const cfJwt = Astro.request.headers.get('cf-access-jwt-assertion');
const isDev = import.meta.env.DEV;
const sessionActive = Boolean(cfJwt || isDev);
const loginTimestamp = new Date().toLocaleString('en-US', {
    month: 'short',
    day: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    hour12: true
});

const getStatusColor = (status) => {
    if (status === 'Live') return '#1A1A1A'; // Black
    if (status === 'Stale') return '#6B6560'; // Gray
    return '#C8BCA8'; // Beige/Unavailable
};
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>

    <!-- Security Bar (Persistent Top) -->
    <div class="global-security-bar">
        <div style="display: flex; gap: 24px; align-items: center; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-primary); font-family: var(--font-ui);">
            <span>CLOUDFLARE ZERO TRUST: <span style="font-weight: 500;">{sessionActive ? 'ACTIVE' : 'EXPIRED'}</span></span>
            <span style="color: var(--text-secondary);">LAST LOGIN: {loginTimestamp}</span>
        </div>
        <a href="/cdn-cgi/access/logout" style="text-decoration: none; color: var(--text-primary); font-family: var(--font-ui); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; padding: 4px 8px; border: 1px solid var(--text-primary);">
            INVALIDATE SESSION
        </a>
    </div>

    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="wordmark">Stilled.</div>
        <ul class="nav-links label-caps">
            <li class={`nav-item ${activePath === '/' ? 'active' : ''}`}>
                <a href="/" style="text-decoration: none; color: inherit; display: block;">Observatory</a>
            </li>
            <li class={`nav-item ${activePath === '/writing-room' ? 'active' : ''}`}>
                <a href="/writing-room" style="text-decoration: none; color: inherit; display: block;">New Post</a>
            </li>
            <li class="nav-item">Theories</li>
            <li class="nav-item">Members</li>
            <li class="nav-item">Settings</li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main class="main-content" style="position: relative; min-height: 100vh; padding-bottom: 80px;">
        <slot />
        
        <!-- Intelligence Gap Indicator (Persistent) -->
        <div class="intel-gap" style="position: absolute; bottom: 0; left: 0; width: 100%; display: flex; align-items: center; padding: 12px 24px; font-family: 'Inter', sans-serif; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text); border-top: 1px solid var(--border); background-color: var(--surface);">
            {pings.map((ping, index) => (
                <>
                    <div class="gap-item" style="display: flex; align-items: center; gap: 8px;">
                        <div style={`width: 6px; height: 6px; border-radius: 50%; background-color: ${getStatusColor(ping.status)};`}></div>
                        <span>{ping.source} — {ping.status} {ping.status === 'Stale' ? `(${ping.lastSyncLabel})` : ''}</span>
                    </div>
                    {index < pings.length - 1 && <div class="gap-divider" style="width: 1px; height: 12px; background-color: var(--border); margin: 0 16px;"></div>}
                </>
            ))}
        </div>
    </main>

</body>
</html>
