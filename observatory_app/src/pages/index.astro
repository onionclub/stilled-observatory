---
import Layout from '../layouts/Layout.astro';
import { get3AMMapData, getTrafficSources } from '../utils/plausible';
import { getYouTubeIntelligence } from '../utils/youtube';
import { getResonanceIndexData, getBaselineEngineData, getConvergenceEvents, getAudienceDepthData, getIntellectualProximityData, getAiSituationalBrief } from '../utils/metrics';
import { pingIntelligenceSources } from '../utils/ping';

const amMapData = await get3AMMapData();
const trafficSources = await getTrafficSources();
const ytData = await getYouTubeIntelligence();
const resonanceData = await getResonanceIndexData();
const baselineData = await getBaselineEngineData();
const convergenceEvents = await getConvergenceEvents();
const audienceDepth = await getAudienceDepthData();
const proximityData = await getIntellectualProximityData();
const aiBrief = await getAiSituationalBrief();
const pings = await pingIntelligenceSources();

const getSourceNotice = (sourceName: string) => {
    const p = pings.find(p => p.source === sourceName);
    if (p && p.status !== 'Live') {
        const days = p.lastSyncDate ? Math.max(1, Math.floor((new Date().getTime() - p.lastSyncDate.getTime()) / (1000 * 60 * 60 * 24))) : 1;
        return `${sourceName} last updated ${days} days ago. ${sourceName} sync unavailable.`;
    }
    return null;
};

// Server-side generation of the Publication heatmap (52 weeks x 7 days)
const totalCells = 52 * 7;
const heatCells = Array.from({ length: totalCells }, (_, i) => {
    const colIndex = Math.floor(i / 7);
    let heat = 0;
    if (colIndex > 43 && Math.random() > 0.4) heat = Math.random() > 0.7 ? 3 : (Math.random() > 0.3 ? 2 : 1);
    else if (colIndex > 20 && Math.random() > 0.85) heat = Math.random() > 0.5 ? 2 : 1;
    else if (colIndex <= 20 && Math.random() > 0.95) heat = 1;
    
    // highlight today
    const isToday = (colIndex === 51 && i % 7 === 3);
    if (isToday) heat = 2;

    return { heat, isToday };
});
---

<Layout title="The Observatory | Stilled." activePath="/">
    <div id="view-observatory" class="view-section active">
        
        <!-- Zone 1: Brief -->
        <div class="brief-zone" style="background-color: var(--surface); border: none;">
            <div class="display-font" style="font-size: 1.5rem; margin-bottom: 8px;">INTELLIGENCE BRIEF</div>
            <p class="ui-font" style="margin: 0; line-height: 1.6; color: var(--text);">
                {aiBrief}
            </p>
        </div>

        <!-- Two Column Layout (Top) -->
        <div class="grid-2col">
            <!-- Left Column -->
            <div class="col-left">
                
                <!-- Zone 2: Resonance Index -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Resonance Index</h2>
                        <div class="label-caps">RANKED BY IMPACT, NOT VIEWS</div>
                    </div>
                    {getSourceNotice('Scroll tracking script') && <div class="ui-font" style="color: var(--text-secondary); padding: 12px; border: 1px solid var(--border); margin-bottom: 16px; font-size: 13px;">{getSourceNotice('Scroll tracking script')}</div>}
                    
                    <div class="resonance-list">
                        {resonanceData.map(item => (
                            <div class="resonance-row">
                                <div class="row-header">
                                    <span class="ui-font theory-title">{item.title}</span>
                                    <span class="display-font theory-score">{item.compositeScore}</span>
                                </div>
                                <div class="bar-container"><div class="bar-fill" style={`width: ${item.compositeScore}%;`}></div></div>
                                <span class="tag">{item.dominantTag.toLowerCase()}</span>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Zone 3: Publication Heatmap -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Publication Record</h2>
                        <div class="label-caps">52 WEEKS</div>
                    </div>
                    <div class="heatmap-container" id="publication-heatmap">
                        {heatCells.map(cell => (
                            <div 
                                class={`heat-cell heat-${cell.heat} ${cell.isToday ? 'today' : ''}`}
                                data-tooltip={cell.heat > 0 ? `Score: ${cell.heat === 3 ? Math.floor(Math.random()*30 + 71) : cell.heat === 2 ? Math.floor(Math.random()*30 + 41) : Math.floor(Math.random()*40 + 1)}` : undefined}
                            ></div>
                        ))}
                    </div>
                    <div class="stat-line">7-day avg: 3.4 posts · 30-day trend: ↑ improving</div>
                </div>

            </div>

            <!-- Right Column -->
            <div class="col-right">
                
                <!-- Zone 4: Traffic Sources -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Traffic Sources</h2>
                        <div class="label-caps">THIS WEEK</div>
                    </div>
                    
                    <div class="traffic-list">
                        {trafficSources.map(source => (
                            <div class="traffic-row" data-tooltip={`${source.percentage}%`}>
                                <div class="traffic-header"><span class="ui-font">{source.source}</span><span class="traffic-val">{source.percentage}%</span></div>
                                <div class="traffic-bar-container"><div class="traffic-bar-fill" style={`width: ${source.percentage}%;`}></div></div>
                            </div>
                        ))}
                    </div>
                    <div class="stat-line" style="margin-top: 16px;">New subscribers this week: 23</div>
                </div>

                <!-- Zone 5: YouTube Intelligence -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">YouTube Intelligence</h2>
                        <div class="label-caps">LINKED VIDEOS</div>
                    </div>
                    {getSourceNotice('YouTube Analytics API') && <div class="ui-font" style="color: var(--text-secondary); padding: 12px; border: 1px solid var(--border); margin-bottom: 16px; font-size: 13px;">{getSourceNotice('YouTube Analytics API')}</div>}
                    
                    <div class="yt-list">
                        {ytData.map(video => (
                            <div class="yt-row">
                                <div class="yt-title ui-font">{video.title}</div>
                                <div class="yt-stats">{video.views} views &nbsp;·&nbsp; {video.retention} avg watch</div>
                                <div class="yt-curve">
                                    <canvas id={`chart-${video.id}`} width="120" height="28"></canvas>
                                </div>
                                <div class="yt-bridge">Bridge rate: {video.bridgeRate} read the paper <span style="opacity:0.5">· {video.conversions} subs</span></div>
                            </div>
                        ))}
                    </div>
                </div>

            </div>
        </div>

        <!-- Two Column Layout (Middle - Fix 1) -->
        <div class="grid-2col">
            <!-- Baseline Engine -->
            <div class="card">
                <div class="card-header">
                    <h2 class="display-font card-title">Baseline Engine</h2>
                    <div class="ui-font" style="font-size: 11px; color: var(--text-secondary); margin-top: 6px;">Compared against your personal historical average for this format and day of week. Threshold: ±1 standard deviation (z-score).</div>
                </div>
                {getSourceNotice('Plausible Analytics') && <div class="ui-font" style="color: var(--text-secondary); padding: 12px; border: 1px solid var(--border); margin-bottom: 16px; font-size: 13px;">{getSourceNotice('Plausible Analytics')}</div>}
                
                <div class="baseline-list">
                    {baselineData.length >= 10 ? (
                        baselineData.map(item => (
                            <div class="baseline-row">
                                <span class="ui-font theory-title">{item.title}</span>
                                <span class="display-font" style="margin-left: auto; margin-right: 16px;">{item.readTimeMetric}</span>
                                <span class={`tag tag-${item.label.split(' ')[0].toLowerCase()}`}>{item.label}</span>
                            </div>
                        ))
                    ) : (
                        <div>
                            {baselineData.map(item => (
                                <div class="baseline-row">
                                    <span class="ui-font theory-title">{item.title}</span>
                                    <span class="display-font" style="margin-left: auto; margin-right: 16px;">{item.readTimeMetric}</span>
                                    <span class={`tag tag-${item.label.split(' ')[0].toLowerCase()}`}>{item.label}</span>
                                </div>
                            ))}
                            <div class="ui-font" style="font-size: 11px; color: var(--text-secondary); margin-top: 12px; font-style: italic;">Baseline data is still building. Minimum 10 essays per format required.</div>
                        </div>
                    )}
                </div>
            </div>

            <!-- Convergence Events -->
            <div class="card">
                <div class="card-header">
                    <h2 class="display-font card-title">Convergence Events</h2>
                    <div class="label-caps">SIGNAL SPIKES & ANOMALIES</div>
                </div>
                
                <div class="convergence-list">
                    {convergenceEvents.map(event => (
                        <div class="convergence-card">
                            <div class="cv-title">{event.title}</div>
                            <div class="cv-signals">{event.signals}</div>
                            <div class="cv-window">{event.windowStr}</div>
                            <div class="cv-verdict">{event.verdict}</div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <!-- Zone 6: The 3AM Map (Fix 2 Redesign) -->
        <div class="card" style="margin-bottom: 24px;">
            <div class="card-header">
                <h2 class="display-font card-title">The 3AM Map</h2>
                <div class="label-caps">WHEN AND WHERE YOUR READERS ARE READING — DEPTH, NOT JUST TRAFFIC</div>
            </div>
            
            <div class="map3-layout">
                <div class="map3-y-wrapper">
                    <div class="map3-y-spacer"></div>
                    <div class="map3-y-axis">
                        <span>12AM</span>
                        <span>3AM</span>
                        <span>6AM</span>
                        <span>9AM</span>
                        <span>12PM</span>
                        <span>3PM</span>
                        <span>6PM</span>
                        <span>9PM</span>
                    </div>
                </div>
                <div class="map3-content">
                    <div class="map3-x-axis">
                        <span>North America East</span>
                        <span>North America West</span>
                        <span>Europe</span>
                        <span>SE Asian Diaspora</span>
                        <span>Other</span>
                    </div>
                    <div class="map3-grid" id="am3-heatmap-new">
                        {amMapData.hours.map(h => (
                            amMapData.regions.map((_, r) => (
                                <div class={`map3-cell map-heat-${amMapData.data[r][h]}`}></div>
                            ))
                        ))}
                    </div>
                </div>
            </div>
            <div class="stat-line" style="font-style: italic; margin-top: 12px;">Cell intensity = read depth (scroll + time on page)</div>
        </div>

        <!-- Zone 9: Audience Depth Index -->
        <div class="grid-2col-half">
            <!-- Left Card -->
            <div class="card">
                <h2 class="display-font card-title" style="margin-bottom: 24px;">Audience Depth</h2>
                {getSourceNotice('Ghost CMS') && <div class="ui-font" style="color: var(--text-secondary); padding: 12px; border: 1px solid var(--border); margin-bottom: 16px; font-size: 13px;">{getSourceNotice('Ghost CMS')}</div>}
                
                {audienceDepth.tiers.map(tier => (
                    <div class="tier-row">
                        <div class="tier-header ui-font">
                            <span>{tier.label}</span>
                            <span>{tier.count} readers</span>
                        </div>
                        <div class="bar-container">
                            <div class={`bar-fill ${tier.isImmersed ? 'tier-4' : ''}`} style={`width: ${tier.percentage}%;`}></div>
                        </div>
                    </div>
                ))}
                
                <div class="tier-footer display-font">Your real audience.</div>
            </div>

            <!-- Right Card -->
            <div class="card">
                <div class="card-header" style="margin-bottom: 16px;">
                    <h2 class="display-font card-title">Tier 4 Archetype</h2>
                    <div class="label-caps">{audienceDepth.archetype.tierSize} READERS — THE PATTERN</div>
                </div>
                
                <div class="archetype-grid">
                    <div>
                        <div class="label-caps arch-stat-label">AVG ESSAYS BEFORE SUBSCRIBING</div>
                        <div class="display-font arch-stat-val">{audienceDepth.archetype.avgEssaysBeforeSub}</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">AVG DAYS FROM FIRST VISIT</div>
                        <div class="display-font arch-stat-val">{audienceDepth.archetype.avgDaysToSub}</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">DISCOVERY PATH</div>
                        <div class="display-font arch-stat-val">{audienceDepth.archetype.discoveryPath}</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">MOST COMMON ENTRY</div>
                        <div class="display-font arch-stat-val">{audienceDepth.archetype.mostCommonEntry}</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zone 10: Intellectual Proximity Layer -->
        <div class="card" style="margin-bottom: 24px;">
            <div class="card-header">
                <h2 class="display-font card-title">Intellectual Proximity</h2>
                <div class="label-caps">READER TRAVERSAL PATHS</div>
            </div>
            
            <div class="proximity-list" style="display: flex; flex-direction: column; gap: 12px;">
                {proximityData.map(node => (
                    <div class="proximity-row" style="display: flex; align-items: baseline; justify-content: space-between; border-bottom: 1px solid var(--border); padding-bottom: 12px;">
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <span class="ui-font" style="font-weight: 500; font-size: 15px;">{node.sourceTitle}</span>
                            <span style="color: var(--text-secondary);">→</span>
                            <span class="ui-font" style="font-weight: 500; font-size: 15px;">{node.destinationTitle}</span>
                        </div>
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <span class="display-font" style="font-size: 18px;">{node.frequencyCount} paths</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>

    </div>

    <!-- Client-side JS -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script is:inline define:vars={{ ytData }}>
        document.addEventListener('DOMContentLoaded', () => {
            // Interactive hover for 3AM Map Cells
            const cells = document.querySelectorAll('.map3-cell');
            cells.forEach(cell => {
                const isZero = cell.classList.contains('map-heat-0');
                if (!isZero) {
                    cell.addEventListener('mouseenter', () => cell.style.opacity = '0.7');
                    cell.addEventListener('mouseleave', () => cell.style.opacity = '1');
                }
            });

            // Chart.js initialization for YouTube Intelligence Feed
            const backgroundPlugin = {
                id: 'customCanvasBackgroundColor',
                beforeDraw: (chart) => {
                    const ctx = chart.canvas.getContext('2d');
                    ctx.save();
                    ctx.globalCompositeOperation = 'destination-over';
                    ctx.fillStyle = '#FAF9F6';
                    ctx.fillRect(0, 0, chart.width, chart.height);
                    ctx.restore();
                }
            };
            Chart.register(backgroundPlugin);

            ytData.forEach(video => {
                const ctx = document.getElementById(`chart-${video.id}`);
                if (ctx) {
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: video.retentionData.map((_, i) => i),
                            datasets: [{
                                data: video.retentionData,
                                borderColor: '#8B7355',
                                backgroundColor: 'transparent',
                                borderWidth: 1.5,
                                tension: 0.4,
                                pointRadius: 0
                            }]
                        },
                        options: {
                            responsive: false,
                            maintainAspectRatio: false,
                            plugins: { 
                                legend: { display: false }, 
                                tooltip: { enabled: false },
                                customCanvasBackgroundColor: { color: '#FAF9F6' }
                            },
                            scales: {
                                x: { display: false },
                                y: { display: false, min: 0, max: 100 }
                            },
                            layout: { padding: 0 }
                        }
                    });
                }
            });
        });
    </script>
</Layout>
