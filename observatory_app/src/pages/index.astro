---
import Layout from '../layouts/Layout.astro';
import { get3AMMapData, getTrafficSources } from '../utils/plausible';
import { getYouTubeIntelligence } from '../utils/youtube';

const amMapData = await get3AMMapData();
const trafficSources = await getTrafficSources();
const ytData = await getYouTubeIntelligence();

// Server-side generation of the Publication heatmap (52 weeks x 7 days)
const totalCells = 52 * 7;
const heatCells = Array.from({ length: totalCells }, (_, i) => {
    const colIndex = Math.floor(i / 7);
    let heat = 0;
    if (colIndex > 43 && Math.random() > 0.4) heat = Math.random() > 0.7 ? 3 : (Math.random() > 0.3 ? 2 : 1);
    else if (colIndex > 20 && Math.random() > 0.85) heat = Math.random() > 0.5 ? 2 : 1;
    else if (colIndex <= 20 && Math.random() > 0.95) heat = 1;
    
    // highlight today
    const isToday = (colIndex === 51 && i % 7 === 3);
    if (isToday) heat = 2;

    return { heat, isToday };
});
---

<Layout title="The Observatory | Stilled." activePath="/">
    <div id="view-observatory" class="view-section active">
        
        <!-- Zone 1: Brief -->
        <div class="brief-zone">
            <div class="label-caps">INTELLIGENCE BRIEF</div>
            <p class="display-font brief-text">
                Your last published theory is performing 2.4× above your 30-day baseline for read depth. Traffic is arriving primarily from YouTube — 67% of this week's new subscribers discovered Stilled through video first. Your academic paper attachment is being downloaded at twice the rate of your previous paperless piece. You last published 41 hours ago.
            </p>
        </div>

        <!-- Two Column Layout (Top) -->
        <div class="grid-2col">
            <!-- Left Column -->
            <div class="col-left">
                
                <!-- Zone 2: Resonance Index -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Resonance Index</h2>
                        <div class="label-caps">RANKED BY IMPACT, NOT VIEWS</div>
                    </div>
                    
                    <div class="resonance-list">
                        <div class="resonance-row">
                            <div class="row-header">
                                <span class="ui-font theory-title">The Architecture of Meaning</span>
                                <span class="display-font theory-score">94</span>
                            </div>
                            <div class="bar-container"><div class="bar-fill" style="width: 94%;"></div></div>
                            <span class="tag">deep reading</span>
                        </div>
                        <div class="resonance-row">
                            <div class="row-header">
                                <span class="ui-font theory-title">Navigating Liminal Time</span>
                                <span class="display-font theory-score">87</span>
                            </div>
                            <div class="bar-container"><div class="bar-fill" style="width: 87%;"></div></div>
                            <span class="tag">return visits</span>
                        </div>
                        <div class="resonance-row">
                            <div class="row-header">
                                <span class="ui-font theory-title">The Void of the Absolute</span>
                                <span class="display-font theory-score">81</span>
                            </div>
                            <div class="bar-container"><div class="bar-fill" style="width: 81%;"></div></div>
                            <span class="tag">conversion</span>
                        </div>
                        <div class="resonance-row">
                            <div class="row-header">
                                <span class="ui-font theory-title">Mechanisms of Self-Dissolution</span>
                                <span class="display-font theory-score">73</span>
                            </div>
                            <div class="bar-container"><div class="bar-fill" style="width: 73%;"></div></div>
                            <span class="tag">deep reading</span>
                        </div>
                        <div class="resonance-row">
                            <div class="row-header">
                                <span class="ui-font theory-title">On the Tyranny of Coherence</span>
                                <span class="display-font theory-score">61</span>
                            </div>
                            <div class="bar-container"><div class="bar-fill" style="width: 61%;"></div></div>
                            <span class="tag">return visits</span>
                        </div>
                    </div>
                </div>

                <!-- Zone 3: Publication Heatmap -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Publication Record</h2>
                        <div class="label-caps">52 WEEKS</div>
                    </div>
                    <div class="heatmap-container" id="publication-heatmap">
                        {heatCells.map(cell => (
                            <div 
                                class={`heat-cell heat-${cell.heat} ${cell.isToday ? 'today' : ''}`}
                                data-tooltip={cell.heat > 0 ? `Score: ${cell.heat === 3 ? Math.floor(Math.random()*30 + 71) : cell.heat === 2 ? Math.floor(Math.random()*30 + 41) : Math.floor(Math.random()*40 + 1)}` : undefined}
                            ></div>
                        ))}
                    </div>
                    <div class="stat-line">7-day avg: 3.4 posts · 30-day trend: ↑ improving</div>
                </div>

            </div>

            <!-- Right Column -->
            <div class="col-right">
                
                <!-- Zone 4: Traffic Sources -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">Traffic Sources</h2>
                        <div class="label-caps">THIS WEEK</div>
                    </div>
                    
                    <div class="traffic-list">
                        {trafficSources.map(source => (
                            <div class="traffic-row" data-tooltip={`${source.percentage}%`}>
                                <div class="traffic-header"><span class="ui-font">{source.source}</span><span class="traffic-val">{source.percentage}%</span></div>
                                <div class="traffic-bar-container"><div class="traffic-bar-fill" style={`width: ${source.percentage}%;`}></div></div>
                            </div>
                        ))}
                    </div>
                    <div class="stat-line" style="margin-top: 16px;">New subscribers this week: 23</div>
                </div>

                <!-- Zone 5: YouTube Intelligence -->
                <div class="card">
                    <div class="card-header">
                        <h2 class="display-font card-title">YouTube Intelligence</h2>
                        <div class="label-caps">LINKED VIDEOS</div>
                    </div>
                    
                    <div class="yt-list">
                        {ytData.map(video => (
                            <div class="yt-row">
                                <div class="yt-title ui-font">{video.title}</div>
                                <div class="yt-stats">{video.views} views &nbsp;·&nbsp; {video.retention} avg watch</div>
                                <div class="yt-curve">
                                    <svg width="120" height="28" viewBox="0 0 120 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d={video.curvePath} stroke="#8B7355" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                                    </svg>
                                </div>
                                <div class="yt-bridge">Bridge rate: {video.bridgeRate} read the paper</div>
                            </div>
                        ))}
                    </div>
                </div>

            </div>
        </div>

        <!-- Two Column Layout (Middle - Fix 1) -->
        <div class="grid-2col">
            <!-- Baseline Engine -->
            <div class="card">
                <div class="card-header">
                    <h2 class="display-font card-title">Baseline Engine</h2>
                    <div class="ui-font" style="font-size: 11px; color: var(--text-secondary); margin-top: 6px;">Compared against your personal historical average for this format and day of week. Threshold: ±1 standard deviation (z-score).</div>
                </div>
                
                <div class="baseline-list">
                    <div class="baseline-row">
                        <span class="ui-font theory-title">The Architecture of Meaning</span>
                        <span class="display-font" style="margin-left: auto; margin-right: 16px;">9.2m read time</span>
                        <span class="tag tag-above">Above Baseline</span>
                    </div>
                    <div class="baseline-row">
                        <span class="ui-font theory-title">The Void of the Absolute</span>
                        <span class="display-font" style="margin-left: auto; margin-right: 16px;">6.4m read time</span>
                        <span class="tag tag-range">Within Range</span>
                    </div>
                    <div class="baseline-row">
                        <span class="ui-font theory-title">On the Tyranny of Coherence</span>
                        <span class="display-font" style="margin-left: auto; margin-right: 16px;">3.1m read time</span>
                        <span class="tag tag-below">Below Baseline</span>
                    </div>
                </div>
            </div>

            <!-- Convergence Events -->
            <div class="card">
                <div class="card-header">
                    <h2 class="display-font card-title">Convergence Events</h2>
                    <div class="label-caps">SIGNAL SPIKES & ANOMALIES</div>
                </div>
                
                <div class="convergence-list">
                    <div class="convergence-card">
                        <div class="cv-title">Navigating Liminal Time</div>
                        <div class="cv-signals">Scroll depth + Return visits + Newsletter click</div>
                        <div class="cv-window">Within 48 hours</div>
                        <div class="cv-verdict">This piece landed.</div>
                    </div>
                    <div class="convergence-card">
                        <div class="cv-title">Mechanisms of Self-Dissolution</div>
                        <div class="cv-signals">Direct sharing + Academic paper download spike</div>
                        <div class="cv-window">Within 48 hours</div>
                        <div class="cv-verdict">Strong academic resonance.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Zone 6: The 3AM Map (Fix 2 Redesign) -->
        <div class="card" style="margin-bottom: 24px;">
            <div class="card-header">
                <h2 class="display-font card-title">The 3AM Map</h2>
                <div class="label-caps">WHEN AND WHERE YOUR READERS ARE READING — DEPTH, NOT JUST TRAFFIC</div>
            </div>
            
            <div class="map3-layout">
                <div class="map3-y-wrapper">
                    <div class="map3-y-spacer"></div>
                    <div class="map3-y-axis">
                        <span>12AM</span>
                        <span>3AM</span>
                        <span>6AM</span>
                        <span>9AM</span>
                        <span>12PM</span>
                        <span>3PM</span>
                        <span>6PM</span>
                        <span>9PM</span>
                    </div>
                </div>
                <div class="map3-content">
                    <div class="map3-x-axis">
                        <span>North America East</span>
                        <span>North America West</span>
                        <span>Europe</span>
                        <span>SE Asian Diaspora</span>
                        <span>Other</span>
                    </div>
                    <div class="map3-grid" id="am3-heatmap-new">
                        {amMapData.hours.map(h => (
                            amMapData.regions.map((_, r) => (
                                <div class={`map3-cell map-heat-${amMapData.data[r][h]}`}></div>
                            ))
                        ))}
                    </div>
                </div>
            </div>
            <div class="stat-line" style="font-style: italic; margin-top: 12px;">Cell intensity = read depth (scroll + time on page)</div>
        </div>

        <!-- Zone 7: Audience Depth -->
        <div class="grid-2col-half">
            <!-- Left Card -->
            <div class="card">
                <h2 class="display-font card-title" style="margin-bottom: 24px;">Audience Depth</h2>
                
                <div class="tier-row">
                    <div class="tier-header ui-font"><span>Tier 1: Read 1 essay</span><span>847 readers</span></div>
                    <div class="bar-container"><div class="bar-fill" style="width: 100%;"></div></div>
                </div>
                <div class="tier-row">
                    <div class="tier-header ui-font"><span>Tier 2: Read 2–5 essays</span><span>203 readers</span></div>
                    <div class="bar-container"><div class="bar-fill" style="width: 24%;"></div></div>
                </div>
                <div class="tier-row">
                    <div class="tier-header ui-font"><span>Tier 3: Read 6–10 essays</span><span>67 readers</span></div>
                    <div class="bar-container"><div class="bar-fill" style="width: 8%;"></div></div>
                </div>
                <div class="tier-row">
                    <div class="tier-header ui-font"><span>Tier 4: Read 10+ essays, returned, subscribed</span><span>31 readers</span></div>
                    <div class="bar-container"><div class="bar-fill tier-4" style="width: 4%;"></div></div>
                </div>
                
                <div class="tier-footer display-font">Your real audience.</div>
            </div>

            <!-- Right Card -->
            <div class="card">
                <div class="card-header" style="margin-bottom: 16px;">
                    <h2 class="display-font card-title">Tier 4 Archetype</h2>
                    <div class="label-caps">31 READERS — THE PATTERN</div>
                </div>
                
                <div class="archetype-grid">
                    <div>
                        <div class="label-caps arch-stat-label">AVG ESSAYS BEFORE SUBSCRIBING</div>
                        <div class="display-font arch-stat-val">4.2</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">AVG DAYS FROM FIRST VISIT</div>
                        <div class="display-font arch-stat-val">11</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">DISCOVERY PATH</div>
                        <div class="display-font arch-stat-val">71% YouTube first</div>
                    </div>
                    <div>
                        <div class="label-caps arch-stat-label">MOST COMMON ENTRY</div>
                        <div class="display-font arch-stat-val">The Architecture of Meaning</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Client-side JS -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            // Interactive hover for 3AM Map Cells
            const cells = document.querySelectorAll('.map3-cell');
            cells.forEach(cell => {
                const isZero = cell.classList.contains('map-heat-0');
                if (!isZero) {
                    cell.addEventListener('mouseenter', () => cell.style.opacity = '0.7');
                    cell.addEventListener('mouseleave', () => cell.style.opacity = '1');
                }
            });
        });
    </script>
</Layout>
