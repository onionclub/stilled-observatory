---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stilled | Counsel">
  <div class="container relative min-h-screen flex-center flex-col" style="padding-top: 8rem; padding-bottom: 8rem;">
    <div class="counsel-wrapper animate-fade-up text-center">
      <h1 class="text-massive">Counsel</h1>
      <p class="counsel-intro delay-100 animate-fade-up">
        High-level consulting and 1-on-1 synthesis. Intimate, forensic, and objective.
      </p>

      <form class="contact-form delay-300 animate-fade-up flex-col" onsubmit="event.preventDefault();">
        <div class="input-group">
          <input type="text" id="name" required placeholder="Name" />
        </div>
        <div class="input-group">
          <input type="email" id="email" required placeholder="Email address" />
        </div>
        <div class="input-group">
          <textarea id="inquiry" rows="4" required placeholder="Nature of inquiry..."></textarea>
        </div>
        <button type="submit" class="submit-btn text-subtle">Submit Request</button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .counsel-wrapper {
    max-width: 600px;
    width: 100%;
  }

  .counsel-intro {
    opacity: 0.8;
    margin-bottom: 4rem;
    font-size: 1.125rem;
  }

  .contact-form {
    gap: 2rem;
    text-align: left;
  }

  .input-group {
    width: 100%;
  }

  input, textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(26, 26, 26, 0.2);
    padding: 1rem 0;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--charcoal);
    transition: border-color var(--transition-medium);
    resize: vertical;
  }

  input:focus, textarea:focus {
    outline: none;
    border-bottom-color: rgba(26, 26, 26, 0.8);
  }
  
  input::placeholder, textarea::placeholder {
    color: rgba(26, 26, 26, 0.4);
  }

  .submit-btn {
    align-self: flex-start;
    background: transparent;
    border: 1px solid rgba(26, 26, 26, 0.2);
    padding: 1rem 3rem;
    cursor: pointer;
    transition: all var(--transition-medium);
    margin-top: 1rem;
  }

  .submit-btn:hover {
    background: rgba(26, 26, 26, 0.05);
    border-color: rgba(26, 26, 26, 0.6);
  }
</style>
