---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Stilled | Artifacts">
  <div class="container relative min-h-screen flex-col" style="padding-top: 12rem;">
    <h1 class="text-massive animate-fade-up">Artifacts</h1>
    <p class="text-subtle animate-fade-up delay-100 mb-massive">Digital products, analytical tools, and published works.</p>
    
    <div class="artifacts-grid">
      <div class="artifact-item animate-fade-up delay-300">
        <div class="artifact-image">
          <img src="https://images.unsplash.com/photo-1544365558-35aa4afcf11f?w=800" alt="Artifact 1" loading="lazy" />
        </div>
        <div class="artifact-meta">
          <h2 class="artifact-title">The Meta-Framework</h2>
          <p class="artifact-desc">A comprehensive guide to identity reconstruction. Physical edition.</p>
          <span class="artifact-price">$40.00</span>
        </div>
      </div>
      
      <div class="artifact-item animate-fade-up delay-500">
        <div class="artifact-image">
          <img src="https://images.unsplash.com/photo-1604871000636-074fa5117945?w=800" alt="Artifact 2" loading="lazy" />
        </div>
        <div class="artifact-meta">
          <h2 class="artifact-title">Liminal Engine</h2>
          <p class="artifact-desc">A browser environment for analytical reading and attention management.</p>
          <span class="artifact-price">$12.00 / mo</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .mb-massive { margin-bottom: 8rem; }
  
  .artifacts-grid {
    display: flex;
    flex-direction: column;
    gap: 16rem;
    padding-bottom: 12rem;
  }
  
  .artifact-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .artifact-item:nth-child(even) {
    direction: rtl;
  }
  
  .artifact-item:nth-child(even) > * {
    direction: ltr; /* Reset text direction for content */
  }

  .artifact-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4/5;
    border: 1px solid rgba(26, 26, 26, 0.05);
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  .artifact-meta {
    max-width: 400px;
  }

  .artifact-title {
    font-size: clamp(2rem, 3vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .artifact-desc {
    opacity: 0.8;
    margin-bottom: 2rem;
    font-size: 1.125rem;
  }
  
  .artifact-price {
    font-family: var(--font-sans);
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    border-top: 1px solid rgba(26, 26, 26, 0.2);
    padding-top: 1rem;
    display: inline-block;
  }
  
  @media (max-width: 768px) {
    .artifact-item {
      grid-template-columns: 1fr;
      direction: ltr !important;
      gap: 2rem;
    }
    .artifacts-grid {
      gap: 8rem;
    }
  }
</style>
