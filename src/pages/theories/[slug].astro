---
import Layout from '../../layouts/Layout.astro';
import { syntheses } from '../../data/syntheses.js';

export function getStaticPaths() {
  return syntheses.map(theory => ({
    params: { slug: theory.slug },
    props: { theory },
  }));
}

const { theory } = Astro.props;
---

<Layout title={`Stilled | ${theory.title}`}>
  <article class="synthesis-container container">
    <div class="left-col">
      <div class="sticky-wrapper">
        <h1 class="theory-title">{theory.title}</h1>
        <p class="theory-excerpt">{theory.excerpt}</p>
        
        <div class="media-container">
          <iframe 
            src={theory.youtubeUrl} 
            title="YouTube video player" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen>
          </iframe>
        </div>
        
        <div class="diagram-container">
          <img src={theory.diagramUrl} alt="Synthesis Diagram" loading="lazy" />
        </div>
      </div>
    </div>
    
    <div class="right-col prose" set:html={theory.bodyContent}>
      <!-- Content injected here -->
    </div>
  </article>

  <script>
    // IntersectionObserver to gently fade in paragraphs
    const paragraphs = document.querySelectorAll('.prose p, .prose h2, .prose h3');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      rootMargin: '0px 0px -10% 0px',
      threshold: 0.1
    });

    paragraphs.forEach(p => {
      p.classList.add('fade-up-element');
      observer.observe(p);
    });
  </script>
</Layout>

<style>
  .synthesis-container {
    display: grid;
    grid-template-columns: 40% 60%;
    gap: var(--spacing-massive);
    padding-top: calc(var(--spacing-massive) + 4rem);
    padding-bottom: var(--spacing-massive);
  }

  /* Left Column: Sticky */
  .left-col {
    position: relative;
  }

  .sticky-wrapper {
    position: sticky;
    top: 8rem; /* below nav */
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .theory-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin-bottom: 0.5rem;
  }

  .theory-excerpt {
    font-size: 1.125rem;
    opacity: 0.8;
  }

  .media-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    background: #000;
  }

  .media-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .diagram-container img {
    width: 100%;
    height: auto;
    border: 1px solid rgba(26, 26, 26, 0.1);
  }

  /* Right Column: Flowing Text */
  .right-col {
    padding-top: 10vh;
    padding-bottom: 20vh;
  }

  :global(.prose h2) {
    font-size: 2.5rem;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-serif);
    font-weight: 500;
  }
  
  :global(.prose h3) {
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    font-family: var(--font-serif);
    font-weight: 500;
  }

  :global(.prose p) {
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    color: rgba(26, 26, 26, 0.85);
  }

  /* Animation classes applied via JS */
  :global(.fade-up-element) {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  :global(.fade-up-element.visible) {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1024px) {
    .synthesis-container {
      grid-template-columns: 1fr;
    }
    .sticky-wrapper {
      position: static;
    }
    .right-col {
      padding-top: 4rem;
    }
  }
</style>
